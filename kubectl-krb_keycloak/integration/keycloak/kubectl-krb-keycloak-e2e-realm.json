{
  "id": "kubectl-krb-keycloak-e2e",
  "realm": "kubectl-krb-keycloak-e2e",
  "enabled": true,
  "sslRequired": "none",
  "browserFlow": "browser-with-kerberos",
  "authenticationFlows": [
    {
      "alias": "browser-with-kerberos",
      "description": "Require SPNEGO so the test cannot fall back to an interactive login",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-spnego",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10,
          "userSetupAllowed": false
        }
      ]
    }
  ],
  "requiredActions": [
    {
      "alias": "VERIFY_PROFILE",
      "name": "Verify Profile",
      "providerId": "VERIFY_PROFILE",
      "enabled": false,
      "defaultAction": false,
      "priority": 40,
      "config": {}
    }
  ],
  "clients": [
    {
      "clientId": "kubectl-e2e",
      "name": "kubectl-krb_keycloak end-to-end test",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:8000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    }
  ],
  "components": {
    "org.keycloak.storage.UserStorageProvider": [
      {
        "name": "ldap-with-kerberos",
        "providerId": "ldap",
        "subComponents": {
          "org.keycloak.storage.ldap.mappers.LDAPStorageMapper": [
            {
              "name": "username",
              "providerId": "user-attribute-ldap-mapper",
              "config": {
                "user.model.attribute": ["username"],
                "ldap.attribute": ["uid"],
                "read.only": ["true"],
                "always.read.value.from.ldap": ["false"],
                "is.mandatory.in.ldap": ["true"]
              }
            },
            {
              "name": "first name",
              "providerId": "user-attribute-ldap-mapper",
              "config": {
                "user.model.attribute": ["firstName"],
                "ldap.attribute": ["givenName"],
                "read.only": ["true"],
                "always.read.value.from.ldap": ["true"],
                "is.mandatory.in.ldap": ["true"]
              }
            },
            {
              "name": "last name",
              "providerId": "user-attribute-ldap-mapper",
              "config": {
                "user.model.attribute": ["lastName"],
                "ldap.attribute": ["sn"],
                "read.only": ["true"],
                "always.read.value.from.ldap": ["true"],
                "is.mandatory.in.ldap": ["true"]
              }
            },
            {
              "name": "email",
              "providerId": "user-attribute-ldap-mapper",
              "config": {
                "user.model.attribute": ["email"],
                "ldap.attribute": ["mail"],
                "read.only": ["true"],
                "always.read.value.from.ldap": ["true"],
                "is.mandatory.in.ldap": ["false"]
              }
            },
            {
              "name": "ldap-groups",
              "providerId": "group-ldap-mapper",
              "config": {
                "groups.dn": ["ou=groups,dc=example,dc=test"],
                "group.name.ldap.attribute": ["cn"],
                "group.object.classes": ["groupOfNames"],
                "preserve.group.inheritance": ["false"],
                "ignore.missing.groups": ["false"],
                "membership.ldap.attribute": ["member"],
                "membership.attribute.type": ["DN"],
                "membership.user.ldap.attribute": ["uid"],
                "mode": ["LDAP_ONLY"],
                "user.roles.retrieve.strategy": ["LOAD_GROUPS_BY_MEMBER_ATTRIBUTE"],
                "memberof.ldap.attribute": ["memberOf"],
                "groups.path": ["/"]
              }
            }
          ]
        },
        "config": {
          "enabled": ["true"],
          "priority": ["0"],
          "editMode": ["READ_ONLY"],
          "importEnabled": ["true"],
          "syncRegistrations": ["false"],
          "vendor": ["other"],
          "connectionUrl": ["ldap://ldap.test:389"],
          "authType": ["simple"],
          "bindDn": ["cn=admin,dc=example,dc=test"],
          "bindCredential": ["integration-ldap-password"],
          "usersDn": ["ou=people,dc=example,dc=test"],
          "usernameLDAPAttribute": ["uid"],
          "rdnLDAPAttribute": ["uid"],
          "uuidLDAPAttribute": ["entryUUID"],
          "userObjectClasses": ["inetOrgPerson, organizationalPerson"],
          "searchScope": ["1"],
          "pagination": ["false"],
          "connectionPooling": ["true"],
          "useTruststoreSpi": ["never"],
          "allowKerberosAuthentication": ["true"],
          "useKerberosForPasswordAuthentication": ["false"],
          "kerberosRealm": ["EXAMPLE.TEST"],
          "serverPrincipal": ["HTTP/keycloak.test@EXAMPLE.TEST"],
          "keyTab": ["/kerberos/keycloak.keytab"],
          "allowPasswordAuthentication": ["false"],
          "updateProfileFirstLogin": ["false"],
          "debug": ["false"]
        }
      }
    ]
  }
}
